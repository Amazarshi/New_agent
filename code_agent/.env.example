# 中文注释：通用 OpenAI 兼容模型配置。
# Qwen、OpenAI、DeepSeek、Kimi、GLM 等只要支持 OpenAI Chat Completions 格式，都可以接入。

# 必填：模型服务的 API Key。
LLM_API_KEY=填你的API_KEY

# 必填：模型名称。
# Qwen 示例：qwen-plus
# OpenAI 示例：gpt-4.1-mini
# DeepSeek 示例：deepseek-chat
LLM_MODEL=qwen-plus

# 必填：OpenAI 兼容接口地址。
# Qwen 示例：https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI 示例：https://api.openai.com/v1
# DeepSeek 示例：https://api.deepseek.com
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
